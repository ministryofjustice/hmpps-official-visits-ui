{% extends "partials/layout.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% set pageTitle = "Movement slips" %}

{% block pageScripts %}
  <script type="text/javascript" nonce="{{ cspNonce }}">
    const printOptionsButton = document.getElementById('print-button');
    if (printOptionsButton) {
      printOptionsButton.classList.remove('govuk-!-display-none')
      printOptionsButton.onclick = () => {
        window.print()
      }
    }
    </script>
{% endblock %}

{% block content %}

  {{ govukButton({
      id: "print-button",
      text: "Print movement slips",
      href: "#",
      classes: 'govuk-button blue-button govuk-!-display-none-print'
  }) }}

  {% if visits.length == 0 %}
    <p class="govuk-body">No visits found for the selected filters.</p>
  {% endif %}

  {% for visit in visits %}
    <div class="govuk-grid-row dotted-border govuk-!-padding-6 {% if not loop.last %}govuk-!-margin-bottom-6{% endif %}">
      <h1 class="govuk-body govuk-!-font-size-24">
        <b>{{ visit.prisonDescription }}</b> Movement authorisation slip</h1>
      <h2 class="govuk-heading-xl govuk-!-margin-bottom-4">{{ visit.prisoner | firstNameSpaceLastName }}, {{ visit.prisoner.prisonerNumber }}</h2>
      <span class="govuk-hint">{{ visit.prisoner.prisonCode }}-{{ visit.prisoner.cellLocation }}</span>

      {{ govukSummaryList({
        classes: 'govuk-!-margin-top-4',
        rows: [
          {
            key: { text: "Official visit" },
            value: { text: '' }
          },
          {
            key: { text: "Time" },
            value: { html: (visit.startTime | timeStringTo24HourPretty) + ' to ' + (visit.endTime | timeStringTo24HourPretty) + '<br />' + visit.visitDate | formatDate("iiii, d MMMM yyyy") }
          },
          {
            key: { text: "Visit type" },
            value: { text: visit.visitTypeDescription }
          },
          {
            key: { text: "Location" },
            value: { text: visit.locationDescription }
          }
        ] | filterNonFalsy
      }) }}

      <p class="govuk-hint float-right govuk-!-margin-bottom-0">Printed at {{ now | formatDate("HH:mm") }} on {{ now | formatDate("iiii, d MMMM yyyy") }}</p>
    </div>
  {% endfor %}
{% endblock %}
