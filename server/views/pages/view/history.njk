{% extends "partials/layout.njk" %}

{% from "partials/progress-tracker.njk" import progressTracker %}
{% from "partials/miniProfile/macro.njk" import miniProfile %}
{% from "moj/components/timeline/macro.njk" import mojTimeline %}


{% set pageTitle = "Official visit change history" %}

{% block content %}
    <span class="govuk-hint">Manage existing official visits</span>

    <h1 class="govuk-heading-l">Official visit</h1>
    {{ miniProfile(prisoner) }}

    {% if history.length %}
        {{ mojTimeline({
            items: history
        }) }}
    {% else %}
        <p class="govuk-body">No change history found for this official visit.</p>
    {% endif %}
{% endblock %}
