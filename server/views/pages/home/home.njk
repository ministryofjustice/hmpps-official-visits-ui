{% extends "../../partials/layout.njk" %}

{% from "components/card.njk" import card %}

{% set mainClasses = "app-container govuk-body" %}

{% block main %}
  <div class="govuk-width-container" id="before-content">
    {% include 'partials/beforeContent.njk' %}
  </div>
  <main class="govuk-main-wrapper govuk-!-padding-top-0" id="main-content">
    <div class="govuk-width-container">
      <h1 class="govuk-heading-l govuk-!-margin-top-8">Official Visits</h1>
    </div>

    <div class="homepage-card-background">
      <div class="govuk-width-container">
        <div class="govuk-grid-row">
          <div class="govuk-grid-column-full">
            <div class="card-group govuk-grid-row">

              {% if user | hasPermission(PERMISSION.MANAGE) %}
                <div class="govuk-grid-column-one-third card-group__item">
                  {{ card({
                    "href": "/manage/create/search",
                    "clickable": "true",
                    "heading": "Book an official visit",
                    "description": "Book an official visit for a prisoner. You can arrange for an in-person or video visit with any approved contacts.",
                    "data-qa": "book-official-visit-card"
                  }) }}
                </div>
              {% endif %}

              <div class="govuk-grid-column-one-third card-group__item">
                {{ card({
                  "href": "/view/list",
                  "clickable": "true",
                  "heading": "View or cancel existing official visits",
                  "description": "You can view, and cancel, existing official visits by date, prisoner or location.",
                  "data-qa": "view-or-cancel-official-visits-card"
                }) }}
              </div>

              {% if user | hasPermission(PERMISSION.ADMIN) %}
                <div class="govuk-grid-column-one-third card-group__item">
                  {{ card({
                    "href": "/admin/time-slots",
                    "clickable": "true",
                    "heading": "Administer days, slots and locations for official visits",
                    "description": "You can view, create and amend the time slots and locations where official visits can take place in the prison.",
                    "data-qa": "manage-time-slots-card"
                  }) }}
                </div>
              {% endif %}

            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
{% endblock %}
